<?xml version="1.0" ?>
<robot name="ur10e_robot">
  <!-- BASE -->
  <link name="base_link">
    <visual><geometry><cylinder length="0.1" radius="0.1"/></geometry><material name="gray"><color rgba="0.5 0.5 0.5 1"/></material></visual>
    <inertial><mass value="4"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Joint 0: Base -> Shoulder -->
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/><child link="shoulder_link"/>
    <origin xyz="0 0 0.1"/><axis xyz="0 0 1"/>
    <limit effort="330" lower="-6.28" upper="6.28" velocity="2.09"/>
  </joint>
  <link name="shoulder_link">
    <visual><origin xyz="0 0 0.05"/><geometry><cylinder length="0.1" radius="0.08"/></geometry><material name="blue"><color rgba="0.2 0.4 0.8 1"/></material></visual>
    <inertial><mass value="7.7"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Joint 1: Shoulder -> Upper Arm -->
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/><child link="upper_arm_link"/>
    <origin xyz="0 0 0.1" rpy="1.5708 0 0"/><axis xyz="0 0 1"/>
    <limit effort="330" lower="-6.28" upper="6.28" velocity="2.09"/>
  </joint>
  <link name="upper_arm_link">
    <visual><origin xyz="0 0.3 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.6" radius="0.07"/></geometry><material name="green"><color rgba="0.2 0.8 0.4 1"/></material></visual>
    <inertial><mass value="12.9"/><inertia ixx="0.4" ixy="0" ixz="0" iyy="0.4" iyz="0" izz="0.04"/></inertial>
  </link>

  <!-- Joint 2: Upper Arm -> Forearm -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/><child link="forearm_link"/>
    <origin xyz="0 0.6 0"/><axis xyz="0 0 1"/>
    <limit effort="150" lower="-3.14" upper="3.14" velocity="3.14"/>
  </joint>
  <link name="forearm_link">
    <visual><origin xyz="0 0.25 0" rpy="1.5708 0 0"/><geometry><cylinder length="0.5" radius="0.06"/></geometry><material name="yellow"><color rgba="0.8 0.8 0.2 1"/></material></visual>
    <inertial><mass value="3.8"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Joint 3: Forearm -> Wrist 1 -->
  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/><child link="wrist_1_link"/>
    <origin xyz="0 0.5 0" rpy="-1.5708 0 0"/><axis xyz="0 0 1"/>
    <limit effort="54" lower="-6.28" upper="6.28" velocity="3.14"/>
  </joint>
  <link name="wrist_1_link">
    <visual><origin xyz="0 0 0.05"/><geometry><cylinder length="0.1" radius="0.05"/></geometry><material name="purple"><color rgba="0.6 0.2 0.8 1"/></material></visual>
    <inertial><mass value="1.9"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Joint 4: Wrist 1 -> Wrist 2 -->
  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/><child link="wrist_2_link"/>
    <origin xyz="0 0 0.1" rpy="1.5708 0 0"/><axis xyz="0 0 1"/>
    <limit effort="54" lower="-6.28" upper="6.28" velocity="3.14"/>
  </joint>
  <link name="wrist_2_link">
    <visual><origin xyz="0 0 0.05"/><geometry><cylinder length="0.1" radius="0.045"/></geometry><material name="cyan"><color rgba="0.2 0.7 0.8 1"/></material></visual>
    <inertial><mass value="1.9"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>

  <!-- Joint 5: Wrist 2 -> Wrist 3 -->
  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/><child link="wrist_3_link"/>
    <origin xyz="0 0 0.1" rpy="-1.5708 0 0"/><axis xyz="0 0 1"/>
    <limit effort="54" lower="-6.28" upper="6.28" velocity="3.14"/>
  </joint>
  <link name="wrist_3_link">
    <visual><origin xyz="0 0 0.02"/><geometry><cylinder length="0.04" radius="0.04"/></geometry><material name="red"><color rgba="0.8 0.2 0.2 1"/></material></visual>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <link name="ee_link"/>
  <joint name="ee_joint" type="fixed"><parent link="wrist_3_link"/><child link="ee_link"/><origin xyz="0 0 0.04"/></joint>
</robot>
